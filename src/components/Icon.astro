---
interface Props {
  name: "archive" | "arrow" | "car" | "chip" | "moon" | "sun" | "tag" | "cube";
  label?: string;
}

const { name, label } = Astro.props;

const paths = {
  archive:
    '<path d="M3 7h18"/><path d="M5 7l1 12h12l1-12"/><path d="M9 11h6"/>',
  arrow: '<path d="M5 12h14"/><path d="M13 6l6 6-6 6"/>',
  car: '<path d="M5 17h14"/><path d="M6 17l1.4-6.3A2.2 2.2 0 0 1 9.5 9h5a2.2 2.2 0 0 1 2.1 1.7L18 17"/><circle cx="8" cy="17" r="2"/><circle cx="16" cy="17" r="2"/>',
  chip:
    '<rect x="7" y="7" width="10" height="10" rx="2"/><path d="M4 10h3"/><path d="M4 14h3"/><path d="M17 10h3"/><path d="M17 14h3"/><path d="M10 4v3"/><path d="M14 4v3"/><path d="M10 17v3"/><path d="M14 17v3"/>',
  moon: '<path d="M20 14.2A7.7 7.7 0 0 1 9.8 4a8 8 0 1 0 10.2 10.2z"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M4.9 4.9l1.4 1.4"/><path d="M17.7 17.7l1.4 1.4"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M4.9 19.1l1.4-1.4"/><path d="M17.7 6.3l1.4-1.4"/>',
  tag: '<path d="M20.6 13.4l-7.2 7.2a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><circle cx="8" cy="8" r="1.5"/>',
  cube: '<path d="M21 16V8l-9-5-9 5v8l9 5 9-5z"/><path d="M3.3 7.5L12 12l8.7-4.5"/><path d="M12 22V12"/>',
};
---

<svg
  aria-hidden={label ? "false" : "true"}
  aria-label={label}
  class="icon"
  fill="none"
  height="18"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="1.8"
  viewBox="0 0 24 24"
  width="18"
  set:html={paths[name]}
/>
