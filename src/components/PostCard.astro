---
import type { CollectionEntry } from "astro:content";
import { formatPostDate } from "../lib/posts";

interface Props {
  post: CollectionEntry<"posts">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const href = `/posts/${post.id}/`;
---

<article class:list={["post-card", { featured }]}>
  <a href={href} class="post-card-link" aria-label={`Read ${post.data.title}`}>
    <div class="post-card-media" style={post.data.coverImage ? `background-image: url('${post.data.coverImage}')` : ""}>
      {!post.data.coverImage && <span>{post.data.category}</span>}
    </div>
    <div class="post-card-body">
      <div class="post-meta">
        <span>{post.data.category}</span>
        <span>{formatPostDate(post.data.date)}</span>
      </div>
      <h2>{post.data.title}</h2>
      <p>{post.data.excerpt}</p>
      <div class="tag-row" aria-label="Tags">
        {post.data.tags.slice(0, featured ? 6 : 4).map((tag) => <span>#{tag}</span>)}
      </div>
    </div>
  </a>
</article>
