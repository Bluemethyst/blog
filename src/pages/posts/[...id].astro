---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatPostDate } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="article">
    <header class="article-head">
      <p class="meta">
        {post.data.category}
        <span aria-hidden="true">/</span>
        {formatPostDate(post.data.date)}
        {post.data.status && <><span aria-hidden="true">/</span>{post.data.status}</>}
      </p>
      <h1>{post.data.title}</h1>
      <p>{post.data.excerpt}</p>
      {post.data.tags.length > 0 && (
        <div class="tag-row">
          {post.data.tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
        </div>
      )}
    </header>

    {post.data.coverImage && (
      <img class="article-cover" src={post.data.coverImage} alt="" loading="eager" />
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
