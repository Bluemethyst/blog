---
import Icon from "../components/Icon.astro";
import PostItem from "../components/PostItem.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCategoryCounts, getPublishedPosts } from "../lib/posts";

const posts = await getPublishedPosts();
const latest = posts.slice(0, 4);
const categoryCounts = getCategoryCounts(posts);
const categories = ["Cars", "Technology", "Minecraft", "Notes"].filter(
    (category) => categoryCounts[category],
);
---

<BaseLayout>
    <section class="intro">
        <p class="kicker">personal notebook</p>
        <h1>everything i do.</h1>
        <p>Cars, electronics, fixes, tests, and notes worth finding again.</p>
        <div class="quick-links" aria-label="Quick links">
            <a href="/posts/"><Icon name="archive" /> archive</a>
            <a href="/tags/"><Icon name="tag" /> tags</a>
        </div>
    </section>

    <section class="section">
        <div class="section-title">
            <h2>latest</h2>
            <a href="/posts/">all posts</a>
        </div>

        {
            latest.length > 0 ? (
                <div class="post-list">
                    {latest.map((post) => (
                        <PostItem post={post} />
                    ))}
                </div>
            ) : (
                <p class="empty">
                    Add a post in PagesCMS and it will show up here.
                </p>
            )
        }
    </section>

    {
        categories.length > 0 && (
            <section class="section">
                <div class="section-title">
                    <h2>threads</h2>
                </div>
                <div class="topic-list">
                    {categories.map((category) => (
                        <span>
                            {category}
                            <small>{categoryCounts[category]}</small>
                        </span>
                    ))}
                </div>
            </section>
        )
    }
</BaseLayout>
