---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Everything Log.">
  <section class="page-header about-header">
    <p class="eyebrow">About</p>
    <h1>A personal blog with workshop fingerprints.</h1>
    <p>
      This is the place for the things that deserve a permanent note: car work,
      tutorials, tech rabbit holes, Minecraft builds, setup notes, failures, fixes,
      and the occasional "future me will need this" breadcrumb.
    </p>
  </section>

  <section class="note-grid">
    <div>
      <span>01</span>
      <h2>Cars</h2>
      <p>Install logs, wiring notes, parts research, diagnostics, and lessons learned the slow way.</p>
    </div>
    <div>
      <span>02</span>
      <h2>Technology</h2>
      <p>Software, devices, tooling, homelab notes, and fixes that took too long to find once.</p>
    </div>
    <div>
      <span>03</span>
      <h2>Builds</h2>
      <p>Games, Minecraft projects, design notes, screenshots, and world-building progress.</p>
    </div>
  </section>
</BaseLayout>
